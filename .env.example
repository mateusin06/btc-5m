# ===========================================
# Polymarket BTC 5-Min Up/Down Bot - Variáveis de ambiente
# ===========================================
# Referência das variáveis usadas pelo bot. A config é passada pela dashboard ao iniciar
# (Supabase); não é obrigatório usar arquivo .env. Para scripts manuais (setup_creds, check_balance,
# set_allowances), defina as variáveis no ambiente (export) ou crie .env se preferir.

# Chave privada da sua carteira (MetaMask etc.). Pode ser com ou sem prefixo 0x
POLY_PRIVATE_KEY=0x...

# Credenciais API derivadas (execute setup_creds.py uma vez para gerar)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Endereço da carteira que detém os fundos (proxy/funder)
# Para MetaMask: mesmo que o endereço da carteira
# Para Magic/Email: endereço da carteira proxy
POLY_FUNDER_ADDRESS=0x...

# Tipo de assinatura: 0=EOA/MetaMask, 1=Magic/Email, 2=Proxy
POLY_SIGNATURE_TYPE=1

# Bankroll inicial em USDC
STARTING_BANKROLL=10.0

# Aposta mínima em USDC (Polymarket exige mínimo 5 shares)
MIN_BET=5.0

# Modo do bot: safe, aggressive, degen
BOT_MODE=safe

# Modo aggressive: % da banca por aposta (ex: 25 = 25%)
AGGRESSIVE_BET_PCT=25

# Preço máximo do token em dólares (0.90 = 90 centavos)
MAX_TOKEN_PRICE=0.90

# Arbitragem: lucro mínimo para considerar arb (0.04 = 4%; usar 0.02–0.03 para mais oportunidades)
ARB_MIN_PROFIT_PCT=0.04

# Dashboard com login (Supabase) — opcional; padrão já preenchido
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
